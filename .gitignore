# =============================================================================
# .gitignore — comprehensive template
# Sections: OS, Editors, Bash, Python, C/C++, Qt, CMake, Debian packaging
# Remove sections not relevant to your project.
# =============================================================================


# -----------------------------------------------------------------------------
# OS / filesystem noise
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*~
.fuse_hidden*
.nfs*


# -----------------------------------------------------------------------------
# Editors
# -----------------------------------------------------------------------------

# Vim / Neovim
*.swp
*.swo
*.swn
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
Session.vim
.netrwhist
tags
.tags

# Emacs
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*
.org-id-locations
*_flymake.*

# VS Code
.vscode/
*.code-workspace

# JetBrains (CLion, PyCharm, IDEA …)
.idea/
*.iml
*.iws
*.ipr
out/

# Kate / KDevelop
*.kate-swp
*.kdev4
.kdev4/

# gedit / other lock files
.gedit-save-*


# -----------------------------------------------------------------------------
# Bash / Shell
# -----------------------------------------------------------------------------

# Test output and temp files left by scripts
*.log
*.tmp
*.bak
*.orig
*.rej

# ShellCheck cache
.shellcheckrc.cache


# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/
.env

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST
pip-wheel-metadata/
.eggs/

# mypy / pyright / ruff caches
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.ruff_cache/

# pytest
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints


# -----------------------------------------------------------------------------
# C / C++
# -----------------------------------------------------------------------------
*.o
*.lo
*.la
*.a
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Autotools
Makefile.in
/autom4te.cache
/aclocal.m4
/compile
/configure
/depcomp
/install-sh
/missing
/stamp-h1
config.log
config.status
libtool

# Static analysis
*.gcno
*.gcda
*.gcov


# -----------------------------------------------------------------------------
# Qt
# -----------------------------------------------------------------------------
# qmake generated
*.pro.user
*.pro.user.*
Makefile.Debug
Makefile.Release
debug/
release/
.qmake.stash
.qmake.cache

# moc / uic / rcc generated sources
moc_*.cpp
moc_*.h
ui_*.h
qrc_*.cpp

# Qt Creator
*.autosave
CMakeLists.txt.user
CMakeLists.txt.user.*


# -----------------------------------------------------------------------------
# CMake
# -----------------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
cmake_uninstall.cmake
install_manifest.txt
CTestTestfile.cmake
_deps/
compile_commands.json

# Out-of-source build directories (common naming conventions)
build/
build-*/
Build/
[Bb]uild*/
_build/


# -----------------------------------------------------------------------------
# Meson / Ninja
# -----------------------------------------------------------------------------

# Meson build directories (any name is valid; these are the common ones)
build/
builddir/
_build/
build-*/
*-build/

# Meson internals inside a build dir
meson-info/
meson-logs/
meson-private/

# Ninja build files (generated by Meson inside the build dir)
build.ninja
.ninja_deps
.ninja_log
rules.ninja

# Meson wrap dependency download cache
subprojects/packagecache/

# compile_commands.json (also generated by Meson/Ninja, already in CMake section)
compile_commands.json


# -----------------------------------------------------------------------------
# Debian packaging build artifacts
# -----------------------------------------------------------------------------

# debuild / dpkg-buildpackage output (one level up from source tree)
../*.deb
../*.ddeb
../*.dsc
../*.tar.gz
../*.tar.xz
../*.tar.bz2
../*.changes
../*.build
../*.buildinfo
../*.upload
../debian/

# Inside source tree
debian/.debhelper/
debian/debhelper-build-stamp
debian/files
debian/tmp/
debian/*.substvars
debian/*.debhelper
debian/*.log
debian/uc-tool-mx/

# lintian overrides cache
.lintian-overrides.cache

